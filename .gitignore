# ----------------------------------------------------------------------
# Dependencies
# ----------------------------------------------------------------------
# Ignore node_modules everywhere (root, frontend, and backend)
node_modules/

# ----------------------------------------------------------------------
# Environment Variables (Keep secrets out of version control)
# ----------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ----------------------------------------------------------------------
# Build Outputs
# ----------------------------------------------------------------------
# Vite (Frontend) build output
/frontend/dist/
/frontend/dist-ssr/

# Common build outputs (just in case)
build/
out/
dist/

# ----------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----------------------------------------------------------------------
# OS / System Files
# ----------------------------------------------------------------------
# Since you are on macOS, this prevents the annoying hidden folder files
.DS_Store
.AppleDouble
.LSOverride
Icon?

# Windows (if other developers use Windows)
Thumbs.db
ehthumbs.db
Desktop.ini

# ----------------------------------------------------------------------
# Editor & IDE specific files
# ----------------------------------------------------------------------
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# WebStorm / IntelliJ
.idea/

# ----------------------------------------------------------------------
# Testing & Coverage
# ----------------------------------------------------------------------
/coverage/
.nyc_output/

# ----------------------------------------------------------------------
# Miscellaneous
# ----------------------------------------------------------------------
.cache/
.eslintcache
